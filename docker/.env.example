# MySQL credentials — copy this file to .env and adjust as needed
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app_database
MYSQL_USER=dev
MYSQL_PASSWORD=secret

# Host user mapping for the app service (prevents file permission issues in Laravel).
# Use your local user/group IDs. On Linux, check with: id -u && id -g
UID=1000
GID=1000

# Xdebug defaults for Linux/Windows/macOS
# Docker Desktop resolves host.docker.internal automatically.
# Native Linux is handled by extra_hosts in docker-compose.
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9003
XDEBUG_DISCOVER_CLIENT_HOST=1
